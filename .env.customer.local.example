# ForgeOS customer PC local environment template.
# Setup copies this file to .env.local only when .env.local does not exist.
# Placeholders only — never commit real credentials.

# Stable local browser origin (do not switch to 127.0.0.1)
NEXT_PUBLIC_APP_URL=http://localhost:3000
FORGEOS_PUBLIC_BASE_URL=http://localhost:3000

# IndexedDB database name — must match in server and browser bundles
FORGEOS_LOCAL_DB_NAME=forgeos:jhgomes:local
NEXT_PUBLIC_FORGEOS_LOCAL_DB_NAME=forgeos:jhgomes:local

# Customer UI defaults
NEXT_PUBLIC_DEFAULT_LOCALE=pt-PT

# Local runtime logging (gitignored)
FORGEOS_LOCAL_LOG_DIR=.customer-pc/logs

# AI: deterministic/mock mode for offline customer PC use
AI_DEFAULT_PROVIDER=deterministic
AI_FALLBACK_PROVIDER=deterministic
AI_ALLOW_BROWSER_PROVIDER_SELECTION=false

# Email delivery disabled for local customer runtime
EMAIL_DELIVERY_PROVIDER=simulation
OUTREACH_DELIVERY_PROVIDER=simulation
OUTREACH_REAL_SEND_ENABLED=false
OUTREACH_TEST_SEND_ENABLED=false

# Outlook local send disabled by default on customer PC
OUTLOOK_LOCAL_SEND_ENABLED=false

# Brevo disabled unless explicitly configured by an authorized operator
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
BREVO_REPLY_TO=
BREVO_WEBHOOK_SECRET=

# Production Supabase disabled for local-only customer runtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional operator overrides (leave blank unless instructed)
ABACUS_API_KEY=
OPENAI_API_KEY=
