{
  "name": "forgeos",
  "private": true,
  "version": "1.0.0",
  "description": "One Operating System for the Modern Factory",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@forgeos/web",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20"
  }
}
