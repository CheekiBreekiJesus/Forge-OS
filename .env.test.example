# ForgeOS acceptance / E2E environment (copy values into shell or CI; do not commit secrets).
# Playwright acceptance config injects these into the dev webServer automatically.

FORGEOS_E2E=true
NEXT_PUBLIC_FORGEOS_LOCAL_DB_NAME=forgeos:e2e:acceptance
FORGEOS_LOCAL_DB_NAME=forgeos:e2e:acceptance

AI_DEFAULT_PROVIDER=deterministic
AI_FALLBACK_PROVIDER=deterministic
AI_OUTREACH_PROVIDER=deterministic
OUTREACH_DELIVERY_PROVIDER=simulation

# Optional live Abacus smoke (never run in CI or npm run validate):
# FORGEOS_LIVE_AI=1
# ABACUS_API_KEY=replace-with-abacus-key
