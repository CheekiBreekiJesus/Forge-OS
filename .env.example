# ForgeOS local development placeholders.
# Copy to .env.local when real values are introduced.

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase placeholders for the persistent MVP.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key-only

# =============================================================================
# FORGEOS AI GATEWAY
# =============================================================================

AI_DEFAULT_PROVIDER=abacus
AI_FALLBACK_PROVIDER=deterministic
AI_REQUEST_TIMEOUT_MS=45000
AI_MAX_RETRIES=2
AI_LOG_PROMPTS=false
AI_LOG_RESPONSES=false
AI_ALLOW_BROWSER_PROVIDER_SELECTION=false

# Outreach capability settings describe the task, not one provider.
AI_OUTREACH_PROVIDER=abacus
AI_OUTREACH_PROFILE=outreach-fast
AI_OUTREACH_LANGUAGE=pt-PT
AI_OUTREACH_TONE=professional
AI_OUTREACH_SPEED=fast
AI_OUTREACH_REASONING=low
AI_OUTREACH_TEMPERATURE=0.25
AI_OUTREACH_TOP_P=0.90
AI_OUTREACH_MAX_TOKENS=700

# Abacus.AI active provider. Do not commit real keys.
ABACUS_API_KEY=replace-with-abacus-key
ABACUS_MODEL=OPENAI_GPT5_4_MINI
ABACUS_TRANSPORT=python-bridge
ABACUS_PYTHON_BIN=python
ABACUS_TIMEOUT_MS=
ABACUS_MAX_RETRIES=
ABACUS_TEMPERATURE_OVERRIDE=
ABACUS_TOP_P_OVERRIDE=
ABACUS_MAX_TOKENS_OVERRIDE=
ABACUS_TONE_OVERRIDE=
ABACUS_SPEED_OVERRIDE=
ABACUS_REASONING_OVERRIDE=

# Abacus model hints. Run `npm run ai:models -- --provider abacus` for the generated catalog.
# OpenAI: OPENAI_GPT4O, OPENAI_GPT4O_MINI, OPENAI_O3, OPENAI_O4_MINI, OPENAI_GPT5,
# OPENAI_GPT5_MINI, OPENAI_GPT5_4, OPENAI_GPT5_4_MINI
# Anthropic: CLAUDE_V4_6_SONNET, CLAUDE_V4_6_OPUS
# Google: GEMINI_3_PRO, GEMINI_3_FLASH
# xAI: XAI_GROK_4
# Local/open: LLAMA3_3_70B, QWEN3_32B, DEEPSEEK_R1
# Abacus: ABACUS_SMAUG3, ABACUS_DRACARYS
# SDK-deprecated examples: OPENAI_GPT3_5, OPENAI_GPT4, GEMINI_1_5_PRO, XAI_GROK,
# CLAUDE_V3_HAIKU, CLAUDE_V4_SONNET, LLAMA3_LARGE_CHAT

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
