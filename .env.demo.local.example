# ForgeOS 0.2.0 local demo environment template.
# Demo scripts inject these values at runtime and do not modify .env.local automatically.
# Copy to .env.local only when you intentionally want persistent local overrides.

NEXT_PUBLIC_APP_URL=http://localhost:3000
FORGEOS_PUBLIC_BASE_URL=http://localhost:3000

# Dedicated demo IndexedDB — isolated from development, E2E, and customer PC databases
FORGEOS_LOCAL_DB_NAME=forgeos:jhgomes:0.2.0-demo
NEXT_PUBLIC_FORGEOS_LOCAL_DB_NAME=forgeos:jhgomes:0.2.0-demo

# Local persistence only (never Supabase for the 0.2.0 walkthrough)
FORGEOS_PERSISTENCE_MODE=local
NEXT_PUBLIC_FORGEOS_PERSISTENCE_MODE=local

NEXT_PUBLIC_DEFAULT_LOCALE=pt-PT
FORGEOS_RUNTIME_MODE=development
FORGEOS_LOCAL_LOG_DIR=.demo/logs

# Deterministic AI — no paid provider calls
AI_DEFAULT_PROVIDER=deterministic
AI_FALLBACK_PROVIDER=deterministic
AI_OUTREACH_PROVIDER=deterministic
AI_ALLOW_BROWSER_PROVIDER_SELECTION=false

# Simulated email delivery — no Brevo or real send
EMAIL_DELIVERY_PROVIDER=simulation
OUTREACH_DELIVERY_PROVIDER=simulation
OUTREACH_REAL_SEND_ENABLED=false
OUTREACH_TEST_SEND_ENABLED=false

# OAuth and hosted integrations disabled for local demo
OUTLOOK_GRAPH_ENABLED=false
OUTLOOK_LIVE_SEND_ENABLED=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Placeholders only — never commit real credentials
BREVO_API_KEY=
ABACUS_API_KEY=
OPENAI_API_KEY=
